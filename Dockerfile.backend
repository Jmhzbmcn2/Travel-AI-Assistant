# ── Base image ─────────────────────────────
FROM python:3.12-slim

# ── Working directory ──────────────────────
WORKDIR /app

# ── Install dependencies (cache layer) ────
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Copy source code ──────────────────────
COPY . .

# ── Expose port ───────────────────────────
EXPOSE 8000

# ── Run server ────────────────────────────
CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8000"]
